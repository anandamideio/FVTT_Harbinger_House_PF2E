{
	"name": "fvtt-harbinger-house-pf2e",
	"version": "1.0.0",
	"description": "Harbinger House PF2e conversion for FoundryVTT",
	"type": "module",
	"scripts": {
		"build": "vite build",
		"build:local": "BUILD=local vite build",
		"watch": "BUILD=local vite build --watch",
		"clean": "rm -rf dist/*.js dist/*.js.map build/",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@league-of-foundry-developers/foundry-vtt-types": "13.346.0-beta.20250812191140",
		"@pixi/assets": "github:foundry-vtt-types/pixi-assets#main",
		"@pixi/compressed-textures": "github:foundry-vtt-types/pixi-compressed-textures#main",
		"@pixi/core": "github:foundry-vtt-types/pixi-core#main",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.5.0",
		"svelte": "^5.55.0",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3",
		"vite": "^8.0.2",
		"vitest": "^4.1.1"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"@pixi/core": "7",
				"@pixi/assets": "7",
				"@pixi/compressed-textures": "7"
			}
		}
	},
	"keywords": [
		"foundry-vtt",
		"pf2e",
		"planescape",
		"harbinger-house"
	],
	"license": "MIT"
}
