{
	"name": "fvtt-harbinger-house-pf2e",
	"version": "1.0.0",
	"description": "Harbinger House PF2e conversion for FoundryVTT",
	"type": "module",
	"scripts": {
		"build": "tsx --import ./scripts/markdown-loader.mjs scripts/build-packs.ts && vite build",
		"build:local": "tsx --import ./scripts/markdown-loader.mjs scripts/build-packs.ts && BUILD=local vite build",
		"build:packs": "tsx --import ./scripts/markdown-loader.mjs scripts/build-packs.ts",
		"import:dd2maps": "tsx scripts/import-dd2vtt.ts --config ./scripts/dd2vtt.config.ts",
		"watch": "BUILD=local vite build --watch",
		"clean": "rm -rf dist/*.js dist/*.js.map build/ packs/",
		"typecheck": "tsc --noEmit",
		"lint": "pnpm eslint ./src --fix",
		"lint:ci": "pnpm eslint ./src",
		"link": "./scripts/link.fish",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:refresh:statblock-fixtures": "tsx scripts/refresh-statblock-fixtures.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@league-of-foundry-developers/foundry-vtt-types": "13.346.0-beta.20250812191140",
		"@pixi/assets": "github:foundry-vtt-types/pixi-assets#main",
		"@pixi/compressed-textures": "github:foundry-vtt-types/pixi-compressed-textures#main",
		"@pixi/core": "github:foundry-vtt-types/pixi-core#main",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/jquery": "^4.0.0",
		"@types/node": "^25.5.2",
		"classic-level": "^3.0.0",
		"eslint": "^10.2.1",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"jquery": "^4.0.0",
		"jsdom": "^29.0.2",
		"svelte": "^5.55.4",
		"tslib": "^2.6.2",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.9",
		"vitest": "^4.1.5"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"@pixi/core": "7",
				"@pixi/assets": "7",
				"@pixi/compressed-textures": "7"
			}
		},
		"onlyBuiltDependencies": [
			"classic-level",
			"esbuild"
		]
	},
	"keywords": [
		"foundry-vtt",
		"pf2e",
		"planescape",
		"harbinger-house"
	],
	"license": "MIT",
	"dependencies": {
		"consola": "^3.4.2"
	}
}
