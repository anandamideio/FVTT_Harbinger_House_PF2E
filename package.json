{
	"name": "fvtt-harbinger-house-pf2e",
	"version": "1.0.0",
	"description": "Harbinger House PF2e conversion for FoundryVTT",
	"type": "module",
	"scripts": {
		"build": "vite build && tsx --import ./scripts/markdown-loader.mjs scripts/build-packs.ts",
		"build:local": "BUILD=local vite build && tsx --import ./scripts/markdown-loader.mjs scripts/build-packs.ts",
		"build:packs": "tsx --import ./scripts/markdown-loader.mjs scripts/build-packs.ts",
		"watch": "BUILD=local vite build --watch",
		"clean": "rm -rf dist/*.js dist/*.js.map build/ packs/",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write",
		"lint:ci": "biome check",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@league-of-foundry-developers/foundry-vtt-types": "13.346.0-beta.20250812191140",
		"@pixi/assets": "github:foundry-vtt-types/pixi-assets#main",
		"@pixi/compressed-textures": "github:foundry-vtt-types/pixi-compressed-textures#main",
		"@pixi/core": "github:foundry-vtt-types/pixi-core#main",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.5.0",
		"classic-level": "^3.0.0",
		"eslint": "^10.1.0",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"svelte": "^5.55.0",
		"tslib": "^2.6.2",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.2",
		"vitest": "^4.1.1"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"@pixi/core": "7",
				"@pixi/assets": "7",
				"@pixi/compressed-textures": "7"
			}
		},
		"onlyBuiltDependencies": [
			"classic-level",
			"esbuild"
		]
	},
	"keywords": [
		"foundry-vtt",
		"pf2e",
		"planescape",
		"harbinger-house"
	],
	"license": "MIT"
}
